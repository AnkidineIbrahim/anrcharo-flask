# ══════════════════════════════════════════════
# VARIABLES D'ENVIRONNEMENT — Anrcharo Flask
# Copiez ce fichier en .env pour le dev local
# Sur Railway : configurez ces variables dans
#   Settings > Variables de votre service
# ══════════════════════════════════════════════

# Flask
FLASK_ENV=production
SECRET_KEY=changez-cette-cle-secrete-en-production-min-32-chars

# PostgreSQL (Railway le fournit automatiquement via $DATABASE_URL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin par défaut (utilisé par init_db.py)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@anrcharo.com
ADMIN_PASSWORD=VotreMotDePasseSecurise@2025!

# Cloudinary (optionnel — pour stocker les images en production)
# Si non défini, les images sont stockées localement (non persistant sur Railway)
# CLOUDINARY_CLOUD_NAME=votre_cloud_name
# CLOUDINARY_API_KEY=votre_api_key
# CLOUDINARY_API_SECRET=votre_api_secret
